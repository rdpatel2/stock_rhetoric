[Unit]
Description=stock-rhetoric Telegram bot
Wants=network-online.target ollama.service
After=network-online.target ollama.service

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/stock-rhetoric
EnvironmentFile=/opt/stock-rhetoric/.env
ExecStart=/opt/stock-rhetoric/.venv/bin/stock-rhetoric-bot
Restart=on-failure
RestartSec=5s
MemoryMax=4G
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/home/ubuntu/.cache /opt/stock-rhetoric
PrivateTmp=true

[Install]
WantedBy=multi-user.target
