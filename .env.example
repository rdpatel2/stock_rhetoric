# Required by SEC EDGAR's fair-access policy. Use your real name + email.
SEC_EDGAR_UA=stock-rhetoric you@example.com

# Local Ollama config (defaults shown).
OLLAMA_MODEL=llama3.2:3b
OLLAMA_HOST=http://localhost:11434
# Hard ceiling for the LLM call. On timeout the report still renders without prose.
OLLAMA_TIMEOUT_S=45

# Override "today" for testing the closed-market path. Format: YYYY-MM-DD.
# STOCK_RHETORIC_TODAY=2026-05-16
